AI_BACKEND_PORT=8787
AI_BACKEND_CORS_ORIGIN=*

# Keep this on the backend only. Never expose it through EXPO_PUBLIC_*.
REPLICATE_API_TOKEN=

# Default first-pass enhancement model. Override for a wall-specific model later.
REPLICATE_MODEL=nightmareai/real-esrgan
REPLICATE_VERSION=
REPLICATE_IMAGE_INPUT_KEY=image
REPLICATE_PROMPT_INPUT_KEY=
REPLICATE_INPUT_JSON={"scale":2,"face_enhance":false}
REPLICATE_FORWARD_SETTINGS=false
REPLICATE_TIMEOUT_MS=120000
REPLICATE_POLL_INTERVAL_MS=1200
